{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "VizWork/**",
      "README.md",
      "WORKFLOW.md",
      "preview.bat"
    ],
    "headers": [
      {
        "source": "**/*.wasm",
        "headers": [ { "key": "Content-Type", "value": "application/wasm" } ]
      },
      {
        "source": "WebPlayer/**/Build/**",
        "headers": [ { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" } ]
      }
    ]
  }
}
